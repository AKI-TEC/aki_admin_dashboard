<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_aki_admin_dashboard_root" model="ir.module.category">
        <field name="name">AKI Admin Dashboard</field>
        <field name="description">Access rights for the AKI Admin Dashboard app.</field>
        <field name="sequence">30</field>
    </record>

    <record id="module_category_aki_admin_dashboard" model="ir.module.category">
        <field name="name">Admin Dashboard</field>
        <field name="description">Controls access to the AKI Admin Dashboard app.</field>
        <field name="sequence">1</field>
        <field name="parent_id" ref="aki_admin_dashboard.module_category_aki_admin_dashboard_root" />
    </record>

    <record id="group_aki_admin_dashboard_user" model="res.groups">
        <field name="name">Admin Dashboard</field>
        <field name="category_id" ref="aki_admin_dashboard.module_category_aki_admin_dashboard" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
        <field name="users" eval="[(4, ref('base.user_admin'))]" />
    </record>

</odoo>
